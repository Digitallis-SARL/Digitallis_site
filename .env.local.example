# ────────────────────────────────────────────────────────
# Digitallis — Configuration locale (à NE PAS commiter)
# Copie ce fichier en .env.local et remplis tes valeurs réelles.
# ────────────────────────────────────────────────────────

# ─── Airtable ───
# PAT créé sur https://airtable.com/create/tokens
# Scopes requis : data.records:read + data.records:write
# Access : base DIGITALLIS
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Base ID — visible dans l'URL Airtable : airtable.com/appXXX...
AIRTABLE_BASE_ID=app8HiP9W1Qa5FVwF

# Nom de la table (défaut: LEADS)
AIRTABLE_TABLE_LEADS=LEADS

# ─── Vercel Blob (uniquement pour test du flux complet en local) ───
# Récupère ce token depuis Vercel → Storage → ton Blob → .env.local snippet
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXX

# ─── Resend (email — déjà configuré côté Vercel) ───
# RESEND_API_KEY=re_XXXXXXXXXXXX
# RECIPIENT_EMAIL=info@digitallis.fr
# FROM_EMAIL=Digitallis <onboarding@resend.dev>

# ─── Webhook IA async (optionnel) ───
# AUDIT_WEBHOOK_URL=https://your-n8n.com/webhook/audit-trigger
# AUDIT_WEBHOOK_SECRET=your-shared-secret
